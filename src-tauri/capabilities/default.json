{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window — scoped to named window only (principle of least privilege).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:app:default",
    "opener:default",
    "core:window:default",
    "core:webview:default",
    "updater:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm"
  ]
}
